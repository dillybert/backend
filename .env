# ─────────────────────────────────────────
# Project
# ─────────────────────────────────────────
PROJECT_NAME=lift
PROJECT_ENV=development
PROJECT_PORT=8080
PROJECT_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lift
POSTGRES_USER=lift
POSTGRES_PASSWORD=lift
POSTGRES_DSN=postgres://lift:lift@postgres:5432/lift?sslmode=disable
DATABASE_MIGRATIONS_DIR=./db/migrations

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=lift
REDIS_DATABASE=0
REDIS_DSN=redis://:lift@redis:6379/0

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Генерируй через: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_ACCESS_TTL=30m      # для клиентов (TMA) и партнёров
JWT_REFRESH_TTL=720h    # 30 дней, только для партнёров и админов

# ─────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_SECRET=your_bot_secret_here

# ─────────────────────────────────────────
# ApiPay (Kaspi Pay)
# ─────────────────────────────────────────
APIPAY_API_KEY=your_apipay_key_here
APIPAY_BASE_URL=https://bpapi.bazarbay.site/api/v1
APIPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────
# Redis UI (tools profile only)
# ─────────────────────────────────────────
REDIS_UI_USER=admin
REDIS_UI_PASSWORD=admin
